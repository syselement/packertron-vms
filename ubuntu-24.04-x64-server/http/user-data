#cloud-config
autoinstall:
  version: 1
  locale: en_US
  keyboard:
    layout: it
  ssh:
    install-server: true
    allow-pw: true
    disable_root: true
    ssh_quiet_keygen: true
    allow_public_ssh_keys: true
  packages:
    - open-vm-tools
    - sudo
  storage:
    layout:
      name: direct
